{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "storage": {
        "rules": "storage.rules"
    },
    "functions": {
        "source": "functions"
    },
    "firestore": [
        {
            "database": "(default)",
            "rules": "firestore.rules"
        },
        {
            "database": "comsaas",
            "rules": "firestore.rules"
        }
    ]
}