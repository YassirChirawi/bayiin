rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---

    // Get the signed-in user's data (cached by Firestore rules for same request)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the user belongs to the store they are trying to access
    function belongsToStore(storeId) {
       // Primary check: JWT Claim (Fastest, supports queries) OR Fallback: Document lookup
       return (request.auth != null && request.auth.token.storeId == storeId) || 
              (request.auth != null && getUserData().storeId == storeId);
    }

    // Type Checks
    function isNumber(num) {
      return num is number || num is float || num is int;
    }
    
    function isString(str) {
      return str is string;
    }

    // --- VALIDATORS ---

    // Validate Store Write
    function isValidStoreUpdate(data) {
       return !data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionStatus', 'stripeCustomerId']);
    }

    // Validate Product
    function isValidProduct(data) {
       return data.storeId != null &&
              data.name is string && data.name.size() > 0 &&
              isNumber(data.price) && data.price >= 0 &&
              isNumber(data.stock) && data.stock >= 0;
    }

    // Validate Order
    function isValidOrder(data) {
       return data.storeId != null &&
              isNumber(data.price) && data.price > 0 &&
              isNumber(data.quantity) && data.quantity > 0 &&
              (!("status" in data) || data.status in ['reçu', 'confirmation', 'packing', 'ramassage', 'livraison', 'reporté', 'livré', 'retour', 'retour en cours', 'annulé', 'pas de réponse', 'pending_catalog']);
    }

    // Validate Expense
    function isValidExpense(data) {
       return data.storeId != null &&
              isNumber(data.amount) && data.amount > 0 &&
              data.label is string && data.label.size() > 0;
    }

    // Check if user is Super Admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Validate Order Transitions
    function isValidTransition(from, to) {
      return (from == 'reçu' && to in ['confirmation', 'packing', 'annulé']) ||
             (from == 'confirmation' && to in ['packing', 'livraison', 'annulé']) ||
             (from == 'packing' && to in ['livraison', 'annulé']) ||
             (from == 'livraison' && to in ['livré', 'retour', 'annulé', 'pas de réponse']) ||
             (from == 'livré' && to == 'retour') ||
             (from == 'pas de réponse' && to in ['confirmation', 'annulé']) ||
             (from == to);
    }

    // Check if store exists and has public catalog enabled
    function isPublicCatalogEnabled(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.publicCatalogEnabled == true;
    }

    // Check if user is a Driver
    function isDriver(storeId) {
      return request.auth != null && getUserData().storeId == storeId && request.auth.token.role == 'driver';
    }

    // Check if the user owns the store
    function isStoreOwner(storeId) {
      return request.auth != null && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    // Check if the user is staff for the store
    function isStoreStaff(storeId) {
      return request.auth != null && getUserData().storeId == storeId && request.auth.token.role == 'staff';
    }

    // Check if user is a Franchise Admin
    function isFranchiseAdmin() {
      return request.auth != null && request.auth.token.role == 'franchise_admin';
    }

    // Check if a store belongs to the franchise admin's franchise
    function inSameFranchise(storeId) {
      return request.auth != null && request.auth.token.franchiseId == get(/databases/$(database)/documents/stores/$(storeId)).data.franchiseId;
    }

    // --- RULES ---

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow write: if request.auth != null && isSuperAdmin();
    }

    // Stores collection
    match /stores/{storeId} {
      allow create: if request.auth != null;
      allow read: if true; 
      allow update, delete: if isStoreOwner(storeId) || isSuperAdmin();

      match /private/{document=**} {
        allow read, write: if isStoreOwner(storeId) || isSuperAdmin();
      }
      
      match /stats/{statId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || (belongsToStore(storeId) && !isDriver(storeId)) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow write: if request.auth != null && (isStoreOwner(storeId) || (belongsToStore(storeId) && !isDriver(storeId)) || isSuperAdmin());
      }
      match /audit_logs/{logId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow create: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
      match /automations/{autoId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow write: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
      match /qa_runs/{docId} {
         allow read, write: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
    }

    // Products
    match /products/{productId} {
       allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || (belongsToStore(resource.data.storeId) && !isDriver(resource.data.storeId)) || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || (belongsToStore(request.resource.data.storeId) && !isDriver(request.resource.data.storeId)) || isSuperAdmin()) && isValidProduct(request.resource.data);
       allow update: if request.auth != null && (isStoreOwner(resource.data.storeId) || (belongsToStore(resource.data.storeId) && !isDriver(resource.data.storeId)) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))) && isValidProduct(request.resource.data);
       allow delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || (belongsToStore(resource.data.storeId) && !isDriver(resource.data.storeId)) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
    }

    // Warehouses
    match /warehouses/{warehouseId} {
       allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }
    
    // Orders
    match /orders/{orderId} {
       allow read: if request.auth != null && (
         isStoreOwner(resource.data.storeId) ||
         resource.data.storeId == getUserData().storeId ||
         isSuperAdmin() ||
         (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)) ||
         resource.data.livreurToken == request.auth.token.uid ||
         (isDriver(resource.data.storeId) && resource.data.status == 'livraison')
       );
       allow read: if resource.data.livreurToken != null;
                      
       allow create: if isValidOrder(request.resource.data) && (
                         (request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin()))
                         || (request.resource.data.status == 'pending_catalog' && isPublicCatalogEnabled(request.resource.data.storeId))
                      );
                         
       allow update: if isValidOrder(request.resource.data) && request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))) &&
                         isValidTransition(resource.data.status, request.resource.data.status);
       
       allow update: if (resource.data.livreurToken != null || isDriver(resource.data.storeId)) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory', 'isPaid', 'driverNote']);
                         
       allow delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // Expenses
    match /expenses/{expenseId} {
       allow read, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || (belongsToStore(resource.data.storeId) && !isDriver(resource.data.storeId)) || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || (belongsToStore(request.resource.data.storeId) && !isDriver(request.resource.data.storeId)) || isSuperAdmin()) && isValidExpense(request.resource.data);
       allow update: if request.auth != null && (isStoreOwner(resource.data.storeId) || (belongsToStore(resource.data.storeId) && !isDriver(resource.data.storeId)) || isSuperAdmin()) && isValidExpense(request.resource.data);
    }

    // Customers
    match /customers/{customerId} {
       allow read, update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || belongsToStore(resource.data.storeId) || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || belongsToStore(request.resource.data.storeId) || isSuperAdmin());
    }

    // Team Management
    match /allowed_users/{userId} {
       allow read: if request.auth != null && (resource.data.email == request.auth.token.email || belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
       allow create: if request.auth != null && (belongsToStore(request.resource.data.storeId) || isStoreOwner(request.resource.data.storeId) || isSuperAdmin());
       allow update, delete: if request.auth != null && (belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }

    // Public Leads
    match /leads/{leadId} {
       allow create: if true;
       allow read: if request.auth != null && (belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }

    // Incidents
    match /incidents/{incidentId} {
      allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || belongsToStore(resource.data.storeId) || isSuperAdmin());
      allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || belongsToStore(request.resource.data.storeId) || isSuperAdmin());
      allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || belongsToStore(resource.data.storeId) || isSuperAdmin());
    }

    // Custom Events
    match /events/{eventId} {
       allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }
    // Product Collections
    match /collections/{collectionId} {
       allow read: if true;
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // System Announcements
    match /system/announcements {
        allow read: if true;
        allow write: if request.auth != null && isSuperAdmin();
    }

    // Assets
    match /assets/{assetId} {
      allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || belongsToStore(resource.data.storeId) || isSuperAdmin());
      allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || belongsToStore(request.resource.data.storeId) || isSuperAdmin());
      allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || belongsToStore(resource.data.storeId) || isSuperAdmin());
    }

    // Franchises collection
    match /franchises/{franchiseId} {
        allow read: if request.auth != null && (
          isSuperAdmin() ||
          (isFranchiseAdmin() && getUserData().franchiseId == franchiseId)
        );
        allow write: if request.auth != null && isSuperAdmin();
    }

    // Driver Applications
    match /driverApplications/{appId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }

    // Drivers
    match /drivers/{driverId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow write: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId)
        );
    }

    // Employees
    match /employees/{employeeId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );

        match /absences/{absenceId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId) ||
                get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId == getUserData().storeId
            );
        }

        match /payroll_history/{payrollId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId) ||
                get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId == getUserData().storeId
            );
        }
    }

    // Purchase Orders
    match /purchase_orders/{orderId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );

        match /receptions/{receptionId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/purchase_orders/$(orderId)).data.storeId) ||
                get(/databases/$(database)/documents/purchase_orders/$(orderId)).data.storeId == getUserData().storeId
            );
        }
    }

    // SAV Returns
    match /returns/{returnId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }
    // SAV Refunds
    match /refunds/{refundId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }
  }
}
