rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---

    // Get the signed-in user's data (cached by Firestore rules for same request)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the user belongs to the store they are trying to access
    function belongsToStore(storeId) {
       // Ideally, we verify against the user document, but for read speed rules
       // often rely on custom claims. Here we stick to document lookup as users are < 100 per store.
       return getUserData().storeId == storeId;
    }

    // Type Checks
    function isNumber(num) {
      return num is number || num is float || num is int;
    }
    
    function isString(str) {
      return str is string;
    }

    // --- VALIDATORS ---

    // Validate Store Write
    function isValidStoreUpdate(data) {
       // Must prevent editing 'subscriptionStatus' directly unless via Admin SDK (backend)
       // But owner might need to update logo/address.
       // We restrict 'plan' and 'subscriptionStatus' updates.
       return !data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionStatus', 'stripeCustomerId']);
    }

    // Validate Product
    function isValidProduct(data) {
       return data.storeId == getUserData().storeId &&
              data.name is string && data.name.size() > 0 &&
              isNumber(data.price) && data.price >= 0 &&
              isNumber(data.stock) &&
              (!("costPrice" in data) || (isNumber(data.costPrice) && data.costPrice >= 0));
    }

    // Validate Order
    function isValidOrder(data) {
       return data.storeId == getUserData().storeId &&
              isNumber(data.price) && data.price >= 0 &&
              isNumber(data.quantity) && data.quantity > 0 &&
              ("status" in data == false || data.status in ['reçu', 'confirmation', 'packing', 'ramassage', 'livraison', 'reporté', 'livré', 'retour', 'retour en cours', 'annulé', 'pas de réponse']) &&
              (!("isPaid" in data) || data.isPaid is bool) &&
              (!("realDeliveryCost" in data) || (isNumber(data.realDeliveryCost) && data.realDeliveryCost >= 0));
    }

    // Check if user is Super Admin (JWT Custom Claim — set by onUserWrite Cloud Function)
    function isSuperAdmin() {
      return request.auth.token.role == 'super_admin';
    }

    // Check if the user owns the store
    function isStoreOwner(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    // Check if user is a Franchise Admin (JWT Custom Claim)
    function isFranchiseAdmin() {
      return request.auth.token.role == 'franchise_admin';
    }

    // Check if a store belongs to the franchise admin's franchise
    function inSameFranchise(storeId) {
      let storeData = get(/databases/$(database)/documents/stores/$(storeId)).data;
      return request.auth.token.franchiseId == storeData.franchiseId;
    }

    // --- RULES ---

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow create: if request.auth != null && request.auth.uid == userId; // Initial creation
      allow update: if request.auth != null && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow write: if request.auth != null && isSuperAdmin(); // Super admin can do anything
    }

    // Stores collection
    match /stores/{storeId} {
      allow create: if request.auth != null;
      allow read: if true; // Public access for Catalog Branding
      allow update: if request.auth != null && (( (belongsToStore(storeId) || resource.data.ownerId == request.auth.uid) && isValidStoreUpdate(request.resource.data)) || isSuperAdmin());
      allow delete: if request.auth != null && isSuperAdmin();
      
      match /stats/{statId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow write: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
      match /audit_logs/{logId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow create: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
      match /automations/{autoId} {
         allow read: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(storeId)));
         allow write: if request.auth != null && (isStoreOwner(storeId) || belongsToStore(storeId) || isSuperAdmin());
      }
    }

    // Products
    match /products/{productId} {
       allow read: if true; // Public access for Catalog
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
    }

    // Warehouses (Épique 5)
    match /warehouses/{warehouseId} {
       allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }
    
    // Orders
    match /orders/{orderId} {
       allow read: if request.auth != null && (
         isStoreOwner(resource.data.storeId) ||
         resource.data.storeId == getUserData().storeId ||
         isSuperAdmin() ||
         // Franchise admin can read all stores in their franchise
         (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)) ||
         // Livreur reads via token — no auth required
         resource.data.livreurToken == request.auth.token.uid
       );
       // Livreur read via token
       // (Security note: because drivers are unauthenticated, anyone with the token can read the order. 
       // We allow any document with a token to be read, and rely on the unguessable token as the secret)
       allow read: if resource.data.livreurToken != null;
                      
       allow create: if (request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin()))
                        || (request.resource.data.status == 'pending_catalog');
                        
       allow update: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
       
       // Allow livreur to update status and add notes via token (no auth, but document must already have the token)
       allow update: if resource.data.livreurToken != null &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory', 'isPaid', 'driverNote']);
                        
       allow delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // Expenses
    match /expenses/{expenseId} {
       allow read, write: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // Customers
    match /customers/{customerId} {
       allow read, write: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // Team Management
    match /allowed_users/{userId} {
       allow read: if request.auth != null && (resource.data.email == request.auth.token.email || belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
       allow create: if request.auth != null && (belongsToStore(request.resource.data.storeId) || isStoreOwner(request.resource.data.storeId) || isSuperAdmin());
       allow update, delete: if request.auth != null && (belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }

    // Public Leads
    match /leads/{leadId} {
       allow create: if true;
       allow read: if request.auth != null && (belongsToStore(resource.data.storeId) || isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }
    // Custom Events (Planning)
    match /events/{eventId} {
       allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }
    // Product Collections (groupings used in Products page)
    match /collections/{collectionId} {
       allow read: if true; // Public for catalog
       allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || request.resource.data.storeId == getUserData().storeId || isSuperAdmin());
       allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || resource.data.storeId == getUserData().storeId || isSuperAdmin());
    }

    // System Announcements
    match /system/announcements {
        allow read: if true;
        allow write: if request.auth != null && isSuperAdmin();
    }

    match /incidents/{incidentId} {
      allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
      allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || isSuperAdmin());
      allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }

    match /assets/{assetId} {
      allow read: if request.auth != null && (isStoreOwner(resource.data.storeId) || isSuperAdmin() || (isFranchiseAdmin() && inSameFranchise(resource.data.storeId)));
      allow create: if request.auth != null && (isStoreOwner(request.resource.data.storeId) || isSuperAdmin());
      allow update, delete: if request.auth != null && (isStoreOwner(resource.data.storeId) || isSuperAdmin());
    }

    // Franchises collection
    match /franchises/{franchiseId} {
        allow read: if request.auth != null && (
          isSuperAdmin() ||
          (isFranchiseAdmin() && getUserData().franchiseId == franchiseId)
        );
        allow write: if request.auth != null && isSuperAdmin();
    }

    // Driver Applications — anyone can create (public recruitment form)
    match /driverApplications/{appId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }

    // Drivers — store owners can manage their driver team
    match /drivers/{driverId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow write: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId)
        );
    }

    // Employees (RH — Vendeurs/Vendeuses) — store owners and staff can manage
    match /employees/{employeeId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );

        // Subcollection: absences
        match /absences/{absenceId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId) ||
                get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId == getUserData().storeId
            );
        }

        // Subcollection: payroll_history
        match /payroll_history/{payrollId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId) ||
                get(/databases/$(database)/documents/employees/$(employeeId)).data.storeId == getUserData().storeId
            );
        }
    }

    // Purchase Orders (Module Achats) — store owners and staff can manage
    match /purchase_orders/{orderId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );

        // Subcollection: receptions
        match /receptions/{receptionId} {
            allow read, write: if request.auth != null && (
                isSuperAdmin() ||
                isStoreOwner(get(/databases/$(database)/documents/purchase_orders/$(orderId)).data.storeId) ||
                get(/databases/$(database)/documents/purchase_orders/$(orderId)).data.storeId == getUserData().storeId
            );
        }
    }

    // SAV Returns — store owners and staff can manage
    match /returns/{returnId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }
    // SAV Refunds — generated automatically when a return is validated
    // Linked to the Finances module (P&L / Remboursements KPI)
    match /refunds/{refundId} {
        allow read: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId) ||
            (isFranchiseAdmin() && inSameFranchise(resource.data.storeId))
        );
        allow create: if request.auth != null && (
            isSuperAdmin() ||
            isStoreOwner(request.resource.data.storeId) ||
            request.resource.data.storeId == getUserData().storeId
        );
        allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            belongsToStore(resource.data.storeId) ||
            isStoreOwner(resource.data.storeId)
        );
    }
  }
}
